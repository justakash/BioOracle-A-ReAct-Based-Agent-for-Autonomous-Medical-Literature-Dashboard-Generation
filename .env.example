# BioOracle Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================
# APPLICATION SETTINGS
# =============================================================
ENV=development
HOST=0.0.0.0
PORT=8000
SECRET_KEY=

# =============================================================
# ANTHROPIC / CLAUDE API
# =============================================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# =============================================================
# BIOMEDICAL API KEYS
# =============================================================

# NCBI / PubMed (get free key at: https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=
NCBI_EMAIL=

# ClinicalTrials.gov (no key required but add email for courtesy)
CLINICALTRIALS_EMAIL=

# Semantic Scholar (optional, increases rate limit)
SEMANTIC_SCHOLAR_API_KEY=

# Europe PMC (no key required)
EUROPE_PMC_EMAIL=

# =============================================================
# DATABASE (PostgreSQL)
# =============================================================
DATABASE_URL=postgresql://biooracle:password@localhost:5432/biooracle_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=biooracle_db
DATABASE_USER=biooracle
DATABASE_PASSWORD=

# =============================================================
# REDIS (for caching and task queue)
# =============================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# =============================================================
# EMAIL / SMTP (for report delivery)
# =============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# =============================================================
# STORAGE PATHS
# =============================================================
DATA_DIR=./data
EXPORT_DIR=./exports
CACHE_DIR=./cache

# =============================================================
# RATE LIMITING
# =============================================================
NCBI_REQUESTS_PER_SECOND=10
SEMANTIC_SCHOLAR_REQUESTS_PER_MINUTE=100

# =============================================================
# RAG / FAISS SETTINGS
# =============================================================
FAISS_INDEX_PATH=./data/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================
# SANDBOX SETTINGS
# =============================================================
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_RETRIES=3
